<Window x:Class="AirConditioningClash.Views.Climatizacao.ClashResolverView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resolver Conflito BIM" Height="500" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F0F0F0">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Conflito Detectado" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="1" Padding="10" CornerRadius="5">
            <StackPanel>
                <TextBlock x:Name="txtViga" Text="Carregando dados do obstáculo..." Foreground="#555" TextWrapping="Wrap"/>

                <TextBlock x:Name="txtTubo" Text="Carregando dados do tubo..." Foreground="#555" Margin="0,5,0,0" TextWrapping="Wrap"/>

                <TextBlock Text="⚠ Interferência geométrica confirmada." Foreground="Red" Margin="0,5,0,0" FontSize="11"/>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="2" Header="Direção do Desvio" Margin="0,15,0,0" Padding="10">
            <StackPanel>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <RadioButton x:Name="rbCima" Grid.Row="0" Grid.Column="0" Content="Por CIMA" IsChecked="True" Margin="0,5"/>
                    <RadioButton x:Name="rbBaixo" Grid.Row="0" Grid.Column="1" Content="Por BAIXO" Margin="0,5"/>

                    <RadioButton x:Name="rbEsquerda" Grid.Row="1" Grid.Column="0" Content="Pela ESQUERDA" Margin="0,5"/>
                    <RadioButton x:Name="rbDireita" Grid.Row="1" Grid.Column="1" Content="Pela DIREITA" Margin="0,5"/>
                </Grid>

                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Margem Lateral (cm):" FontSize="11" Foreground="#555"/>
                        <TextBox x:Name="inputMargem" Text="5" Padding="4" TextAlignment="Center" Margin="0,2,0,0"/>
                        <TextBlock Text="(Distância da curva)" FontSize="9" Foreground="#999" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Espaçamento (cm):" FontSize="11" Foreground="#555"/>
                        <TextBox x:Name="inputFolga" Text="5" Padding="4" TextAlignment="Center" Margin="0,2,0,0"/>
                        <TextBlock Text="(Folga livre)" FontSize="9" Foreground="#999" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Width="100" Height="30" Click="btnCancelar_Click" Background="White" Margin="0,0,10,0"/>
            <Button Content="Aplicar Correção" Width="120" Height="30" Click="btnAplicar_Click" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>