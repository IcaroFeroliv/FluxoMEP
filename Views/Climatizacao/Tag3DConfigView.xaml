<Window x:Class="AirConditioningClash.Views.Climatizacao.Tag3DConfigView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tags — Vista 3D / Corte" Width="390" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Inserir Tags — Vista 3D / Corte" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <GroupBox Header="O que você vai detalhar?" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Margin="5">
                    <RadioButton x:Name="rbPipes"     Content="Tubulações"  GroupName="Categoria" IsChecked="True" Margin="0,0,15,0" Checked="OnCategoryChanged"/>
                    <RadioButton x:Name="rbDucts"     Content="Dutos"       GroupName="Categoria" Margin="0,0,15,0" Checked="OnCategoryChanged"/>
                    <RadioButton x:Name="rbEquipment" Content="Equipamentos" GroupName="Categoria" Checked="OnCategoryChanged"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Família de Tag" Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <TextBlock Text="Selecione a família:"/>
                    <ComboBox x:Name="cmbTagFamilies" Margin="0,5,0,0" DisplayMemberPath="Name"/>
                    <CheckBox x:Name="chkLeader" Content="Criar linha de chamada (Leader)" IsChecked="True" Margin="0,10,0,0"/>
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="grpFiltroTubo" Header="Tipos de Tubo na Vista" Margin="0,0,0,10" Visibility="Collapsed">
                <StackPanel Margin="5">
                    <TextBlock Text="Selecione quais tipos de tubo receberão tag:"
                               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <ListBox x:Name="lstTiposTubo" MaxHeight="130"
                             BorderThickness="1" BorderBrush="#BBBBBB" Margin="0,0,0,6">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="2,2,2,2"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Nome}"
                                          IsChecked="{Binding Selecionado, Mode=TwoWay}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Todos"  Width="60" Height="22" Margin="0,0,6,0" Click="btnTodosTubo_Click"/>
                        <Button Content="Nenhum" Width="60" Height="22" Click="btnNenhumTubo_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Parâmetros" Margin="0,0,0,10">
                <StackPanel Margin="5">

                    <!-- Posição Vertical -->
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Posição Vertical:" VerticalAlignment="Center" MinWidth="155"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbAcima"  Content="Acima"  GroupName="PosicaoVertical" IsChecked="True" Margin="0,0,14,0"/>
                            <RadioButton x:Name="rbAbaixo" Content="Abaixo" GroupName="PosicaoVertical"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Offset Vertical -->
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Offset Vertical (mm):" VerticalAlignment="Center" MinWidth="155"/>
                        <TextBox x:Name="txtOffset" Text="500" Width="80" HorizontalAlignment="Left"
                                 ToolTip="Distância vertical entre a borda do elemento e a cabeça da tag."/>
                    </DockPanel>

                    <!-- Posição Horizontal -->
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Posição Horizontal:" VerticalAlignment="Center" MinWidth="155"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbCentro"   Content="Centro"   GroupName="PosicaoHorizontal" IsChecked="True" Margin="0,0,10,0" Checked="OnHorizontalPositionChanged"/>
                            <RadioButton x:Name="rbDireita"  Content="Direita"  GroupName="PosicaoHorizontal" Margin="0,0,10,0" Checked="OnHorizontalPositionChanged"/>
                            <RadioButton x:Name="rbEsquerda" Content="Esquerda" GroupName="PosicaoHorizontal" Checked="OnHorizontalPositionChanged"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Offset Horizontal -->
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Offset Horizontal (mm):" VerticalAlignment="Center" MinWidth="155"/>
                        <TextBox x:Name="txtOffsetH" Text="300" Width="80" HorizontalAlignment="Left" IsEnabled="False"
                                 ToolTip="Distância horizontal entre a borda do elemento e a cabeça da tag."/>
                    </DockPanel>

                    <!-- Comprimento Mínimo -->
                    <DockPanel>
                        <TextBlock Text="Comprimento mínimo (mm):" VerticalAlignment="Center" MinWidth="155"/>
                        <TextBox x:Name="txtMinLength" Text="500" Width="80" HorizontalAlignment="Left"
                                 ToolTip="Ignora tubos/dutos menores que este valor (mm)."/>
                    </DockPanel>

                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="btnCancel" Content="Cancelar" Width="80" Height="25" Margin="0,0,10,0" Click="btnCancel_Click"/>
                <Button x:Name="btnApply" Content="Aplicar" Width="100" Height="25" Click="btnApply_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
