<Window x:Class="AirConditioningClash.Views.ConflictTypeSelectionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar Tipo de Conflito" Height="350" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Qual tipo de conflito deseja resolver?" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0">
            <RadioButton x:Name="rbEstrutural" Content="🏗️  Estrutural (Vigas, Pilares, Lajes, Paredes)" 
                         FontSize="16" IsChecked="True" Foreground="#333" Padding="10"/>

            <RadioButton x:Name="rbEletrica" Content="⚡  Elétrica (Conduites, Conexões, Luminárias)" 
                         FontSize="16" Foreground="#333" Padding="10"/>

            <RadioButton x:Name="rbHidrossanitario" Content="💧  Hidrossanitário (Tubulações, Conexões, Acessórios)" 
                         FontSize="16" Foreground="#333" Padding="10"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Width="100" Height="30" Click="btnCancelar_Click" Background="White" Margin="0,0,10,0" BorderBrush="#DDD" BorderThickness="1"/>
            <Button Content="Próximo" Width="100" Height="30" Click="btnProximo_Click" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>