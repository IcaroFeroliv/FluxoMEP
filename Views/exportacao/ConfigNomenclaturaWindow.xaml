<Window x:Class="AirConditioningClash.Views.Climatizacao.ConfigNomenclaturaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Nomenclatura de Saída"
        Height="480" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#F4F4F4"
        FontFamily="Segoe UI"
        FontSize="13"
        ResizeMode="CanResize">

    <Window.Resources>

        <SolidColorBrush x:Key="Accent"      Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentHover" Color="#106EBE"/>
        <SolidColorBrush x:Key="AccentPress" Color="#005A9E"/>
        <SolidColorBrush x:Key="TextMain"    Color="#1B1B1B"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#767676"/>
        <SolidColorBrush x:Key="LineBorder"  Color="#D1D1D1"/>
        <SolidColorBrush x:Key="Surface"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgLight"     Color="#F4F4F4"/>

        <!-- Botão primário -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource LineBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBEBEB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DEDEDE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão de transferência (→ / ←) -->
        <Style x:Key="BtnTransfer" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource LineBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DCEEFB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D0E7F8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox separador -->
        <Style x:Key="TxtSeparator" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource LineBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="TextAlignment"   Value="Center"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource BgLight}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource LineBorder}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel>
                <TextBlock Text="Nomenclatura de Saída"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextMain}"/>
                <TextBlock Text="Defina quais parâmetros formarão o nome do arquivo PDF e em que ordem."
                           FontSize="12"
                           Foreground="{StaticResource TextMuted}"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Listas de transferência -->
        <Border Grid.Row="1"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource LineBorder}"
                BorderThickness="1"
                CornerRadius="3"
                Margin="16,12,16,0"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Labels -->
                <TextBlock Grid.Column="0" Grid.Row="0"
                           Text="Disponíveis"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextMain}"
                           Margin="0,0,0,8"/>
                <TextBlock Grid.Column="2" Grid.Row="0"
                           Text="Selecionados (ordem)"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextMain}"
                           Margin="0,0,0,8"/>

                <!-- Lista esquerda -->
                <Border Grid.Column="0" Grid.Row="1"
                        BorderBrush="{StaticResource LineBorder}"
                        BorderThickness="1"
                        CornerRadius="3"
                        ClipToBounds="True">
                    <ListBox ItemsSource="{Binding AvailableParameters}"
                             SelectedItem="{Binding SelectedAvailableParameter}"
                             BorderThickness="0"/>
                </Border>

                <!-- Botões centrais -->
                <StackPanel Grid.Column="1" Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Button Content="&gt;&gt;"
                            Style="{StaticResource BtnTransfer}"
                            Margin="0,0,0,8"
                            Command="{Binding AddParameterCommand}"
                            ToolTip="Adicionar parâmetro"/>
                    <Button Content="&lt;&lt;"
                            Style="{StaticResource BtnTransfer}"
                            Command="{Binding RemoveParameterCommand}"
                            ToolTip="Remover parâmetro"/>
                </StackPanel>

                <!-- Lista direita -->
                <Border Grid.Column="2" Grid.Row="1"
                        BorderBrush="{StaticResource LineBorder}"
                        BorderThickness="1"
                        CornerRadius="3"
                        ClipToBounds="True">
                    <ListBox ItemsSource="{Binding ChosenParameters}"
                             SelectedItem="{Binding SelectedChosenParameter}"
                             BorderThickness="0"/>
                </Border>

            </Grid>
        </Border>

        <!-- Separador -->
        <Border Grid.Row="2"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource LineBorder}"
                BorderThickness="1"
                CornerRadius="3"
                Margin="16,8,16,0"
                Padding="14,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Separador entre parâmetros"
                           Foreground="{StaticResource TextMain}"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="Ex:  -   _   ."
                           FontSize="12"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>
                <TextBox Text="{Binding SeparatorText, UpdateSourceTrigger=PropertyChanged}"
                         Width="52"
                         Style="{StaticResource TxtSeparator}"
                         HorizontalAlignment="Left"/>
            </DockPanel>
        </Border>

        <!-- Rodapé -->
        <Border Grid.Row="3"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource LineBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,12"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar"
                        Style="{StaticResource BtnSecondary}"
                        Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"/>
                <Button Content="Salvar Padrão"
                        Style="{StaticResource BtnPrimary}"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
