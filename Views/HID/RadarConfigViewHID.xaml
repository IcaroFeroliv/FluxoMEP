<Window x:Class="AirConditioningClash.Views.Climatizacao.RadarConfigViewHID"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Radar Climatização" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="O que o Radar deve vigiar?" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Estrutura" FontWeight="SemiBold" Foreground="#007ACC" Margin="0,5"/>
                    <CheckBox x:Name="chkVigas" Content="Vigas (Structural Framing)" Margin="10,2"/>
                    <CheckBox x:Name="chkPilares" Content="Pilares (Columns)" Margin="10,2"/>
                    <CheckBox x:Name="chkLajes" Content="Lajes / Pisos (Floors)" Margin="10,2"/>

                    <TextBlock Text="Arquitetura" FontWeight="SemiBold" Foreground="#007ACC" Margin="0,10,0,5"/>
                    <CheckBox x:Name="chkParedes" Content="Paredes (Walls)" Margin="10,2"/>
                    <CheckBox x:Name="chkForros" Content="Forros (Ceilings)" Margin="10,2"/>

                    <TextBlock Text="Instalações (MEP / Split)" FontWeight="SemiBold" Foreground="#007ACC" Margin="0,10,0,5"/>

                    <CheckBox x:Name="chkDutos" Content="Dutos de Ar (Ducts)" Margin="10,2"/>

                    <CheckBox x:Name="chkTubulacao" Content="Tubulações (Split/Hidro)" Margin="10,2" Background="#E3F2FD"/>
                    <CheckBox x:Name="chkConexoesdeTubo" Content="Conexões de Tubo" Margin="10,2"/>
                    <CheckBox x:Name="chkAcessorios" Content="Acessórios de Tubo" Margin="10,2"/>

                    <CheckBox x:Name="chkEletrocalhas" Content="Eletrocalhas (Cable Tray)" Margin="10,2"/>
                    <CheckBox x:Name="chkGeneric" Content="Modelos Genéricos (Generic Models)" Margin="10,2"/>

                    <TextBlock Text="Elétrica" FontWeight="SemiBold" Foreground="#007ACC" Margin="0,10,0,5"/>
                    <CheckBox x:Name="chkConduites" Content="Conduites (Conduit)" Margin="10,2"/>
                    <CheckBox x:Name="chkConexao" Content="Conexão de Conduite (Conduit Fitting)" Margin="10,2"/>
                    <CheckBox x:Name="chkluminarias" Content="Luminárias (Lighting Fixtures)" Margin="10,2"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Desligar Radar" Click="btnDesligar_Click" Width="100" Height="30" Margin="0,0,10,0" Background="#FFCCCC" Foreground="#CC0000"/>
            <Button Content="Salvar e Ligar" Click="btnSalvar_Click" Width="120" Height="30" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>